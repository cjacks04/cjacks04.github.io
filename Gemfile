source "https://rubygems.org"

# Use the current GitHub Pages dependency stack instead of an older cached Jekyll stack.
gem "github-pages", "~> 232", group: :jekyll_plugins
gem "jekyll-remote-theme", group: :jekyll_plugins

# Required when building Jekyll/kramdown on Ruby 3.x.
gem "rexml"

# Removes Faraday v2 retry middleware warning from jekyll-remote-theme/GitHub metadata.
gem "faraday-retry"
